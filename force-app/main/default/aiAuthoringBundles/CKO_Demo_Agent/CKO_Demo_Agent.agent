system:
  instructions: "You are an AI Agent."
  messages:
    welcome: "Hi, I'm an AI assistant. How can I help you?"
    error: "Sorry, it looks like something has gone wrong."

config:
    developer_name: "CKO_Demo_Agent"
    default_agent_user: "cko_demo_agent@00ddq000009eupv254697110.ext"
    agent_label: "CKO Demo Agent"
    description: "New agent description"

language:
  default_locale: "en_US"
  additional_locales: ""

variables:
  EndUserId: linked string
    source: @MessagingSession.MessagingEndUserId
    description: "This variable may also be referred to as MessagingEndUser Id"
  RoutableId: linked string
    source: @MessagingSession.Id
    description: "This variable may also be referred to as MessagingSession Id"
  ContactId: linked string
    source: @MessagingEndUser.ContactId
    description: "This variable may also be referred to as MessagingEndUser ContactId"
  EndUserLanguage: linked string
    source: @MessagingSession.EndUserLanguage
    description: "This variable may also be referred to as MessagingSession EndUserLanguage"
  VerifiedCustomerId: mutable string
    description: "This variable may also be referred to as VerifiedCustomerId"
  LoyaltyTier: mutable string
    description: "Represents the customer's loyalty tier."
  CheckedChurnScore: mutable boolean = False
    description: "Indicates whether the customer has been checked."
    label: "Checked Churn Score"
  UserID: mutable string
    description: "Represents a unique identifier for the user."
  ChurnScore: mutable number
    label: "Churn Score"

start_agent topic_selector:
  label: "Topic Selector"
  description: "Welcome the user and determine the appropriate topic based on user input"
  reasoning:
    instructions: ->
      | Select the best tool to call based on conversation history and user's intent.
    actions:
      go_to_escalation: @utils.transition to @topic.escalation
      go_to_off_topic: @utils.transition to @topic.off_topic
      go_to_ambiguous_question: @utils.transition to @topic.ambiguous_question
      go_to_Order_Management: @utils.transition to @topic.Order_Management
      go_to_Account_Management: @utils.transition to @topic.Account_Management
      go_to_Process_Refunds: @utils.transition to @topic.Process_Refunds

topic escalation:
  label: "Escalation"
  description: "Handles requests to escalate to a human agent"
  reasoning:
    instructions: ->
      | Apologize for the inconvenience and transfer the user to a human agent.
    actions:
      transfer_to_agent: @utils.escalate

topic off_topic:
  label: "Off Topic"
  description: "Handles queries that do not relate to the agent's capabilities."
  reasoning:
    instructions: ->
      | Politely inform the user that you cannot assist with that topic and ask if they need help with orders, accounts, or refunds.

topic ambiguous_question:
  label: "Ambiguous Question"
  description: "Handles unclear user requests."
  reasoning:
    instructions: ->
      | Ask the user to clarify their request so you can route them to the correct topic.

topic Order_Management:
    label: "Order Management"
    description: "Handles checking order status and tracking."
    reasoning:
        instructions: ->
            |If the user asks for their order status, use {!@actions.Check_Order_Status}.
        actions:
            Check_Order_Status: @actions.Check_Order_Status
                with OrderID = ...

    actions:
        Check_Order_Status:
            label: "Check Order Status"
            description: |
                                                                
                Check order status
            target: "flow://Check_Order"
            inputs:
                OrderID: string
                    label: "OrderID"
                    description: ""
                    is_required: False
                    complex_data_type_name: "lightning__textType"
                    is_user_input: False
                    filter_from_agent: False
                    is_displayable: False
            outputs:
                OrderStatus: string
                    label: "OrderStatus"
                    description: ""
                    complex_data_type_name: "lightning__textType"
                    developer_name: "OrderStatus"
                    is_displayable: False
                    filter_from_agent: False
                TrackingNumber: string
                    label: "TrackingNumber"
                    description: ""
                    complex_data_type_name: "lightning__textType"
                    developer_name: "TrackingNumber"
                    is_displayable: False
                    filter_from_agent: False

topic Account_Management:
    label: "Account Management"
    description: "Handles account updates like changing a user address."
    reasoning:
        instructions: ->
            |If the user asks to update their address, use {!@actions.Update_Address}.
        actions:
            Update_Address: @actions.Update_Address
                with UserAddress = ...







    actions:
        Update_Address:
            label: "Update Address"
            description: |
                                                        
                Update the users address
            target: "flow://Update_Address"
            inputs:
                UserAddress: string
                    label: "UserAddress"
                    description: ""
                    is_required: False
                    complex_data_type_name: "lightning__textType"
                    is_user_input: False
                    filter_from_agent: False
                    is_displayable: False
            outputs:
                SuccessMessage: string
                    label: "SuccessMessage"
                    description: ""
                    complex_data_type_name: "lightning__textType"
                    developer_name: "SuccessMessage"
                    is_displayable: False
                    filter_from_agent: False

topic Process_Refunds:
    label: "Process Refunds"
    description: "Handles refund requests and provides customer profile information."
    reasoning:
        instructions: ->
            if @variables.CheckedChurnScore == False:
                run @actions.GetUserChurnRisk
                    with userid = @variables.EndUserId
                    set @variables.ChurnScore = @outputs.ChurnRisk
                set @variables.CheckedChurnScore = True
            if @variables.ChurnScore >= 75:
                |if the user asks for a refund or return process it using {!@actions.Process_Refund}
            else:
                |if the user asks for a refund or return apologize and inform the user they're not eligible for a refund or a return
        actions:
            Process_Refund: @actions.Process_Refund
                with OrderID = ...
            GetUserChurnRisk: @actions.GetUserChurnRisk
                with userid = ...


    actions:
        Process_Refund:
            label: "Process Refund"
            description: |
                                                                                                                                                        
                Process return / refund
            target: "flow://Process_Refund"
            inputs:
                OrderID: string
                    label: "OrderID"
                    description: ""
                    is_required: False
                    complex_data_type_name: "lightning__textType"
                    is_user_input: False
                    filter_from_agent: False
                    is_displayable: False
            outputs:
                RefundSuccess: boolean
                    label: "RefundSuccess"
                    description: ""
                    complex_data_type_name: "lightning__booleanType"
                    developer_name: "RefundSuccess"
                    is_displayable: False
                    filter_from_agent: False
                ReturnDetails: string
                    label: "ReturnDetails"
                    description: ""
                    complex_data_type_name: "lightning__textType"
                    developer_name: "ReturnDetails"
                    is_displayable: False
                    filter_from_agent: False
        GetUserChurnRisk:
            label: "GetUserChurnRisk"
            description: "Get Users Churn Risk"
            target: "flow://GetUserChurnRisk"
            inputs:
                userid: string
                    label: "userid"
                    description: ""
                    is_required: False
                    complex_data_type_name: "lightning__textType"
                    is_user_input: False
                    filter_from_agent: False
                    is_displayable: False
            outputs:
                ChurnRisk: number
                    label: "ChurnRisk"
                    description: ""
                    complex_data_type_name: "lightning__numberType"
                    developer_name: "ChurnRisk"
                    is_displayable: False
                    filter_from_agent: False

actions:
  Update_Address:
    description: "Updates the physical address of the user"
    label: "Update Address"
    require_user_confirmation: True
    include_in_progress_indicator: True
    source: "Update_Address"
    target: "flow://Update_Address"
    inputs:
      "UserAddress": string
        description: "address of the user"
        label: "Address"
        is_displayable: False
        is_used_by_planner: True
        filter_from_agent: False

  Check_Order_Status:
    description: "Checks the status of an existing order"
    label: "Check Order Status"
    require_user_confirmation: False
    include_in_progress_indicator: True
    source: "Check_Order"
    target: "flow://Check_Order"
    inputs:
      "OrderID": string
        description: "The ID of the order being checked"
        label: "OrderID"
        is_required: True
        is_user_input: False

  Process_Refund:
    description: "Processes return/refund"
    label: "Process Refund"
    require_user_confirmation: False
    include_in_progress_indicator: False
    source: "Process_Refund"
    target: "flow://Process_Refund"
    inputs:
      "OrderID": string
        description: "Id of the order you want to return"
        label: "OrderID"
        is_required: True
        is_user_input: False
    outputs:
      "RefundSuccess": boolean
        description: "returns whether or not the refund was a success"
        label: "RefundSuccess"
        is_displayable: False
        is_used_by_planner: True
        filter_from_agent: False
      "ReturnDetails": string
        description: "returns info about the return"
        label: "ReturnDetails"
        is_displayable: False
        is_used_by_planner: True
        filter_from_agent: False

  GetUserChurnRisk:
    description: "Gets customer churn risk"
    label: "Get User Churn Risk"
    require_user_confirmation: False
    include_in_progress_indicator: False
    source: "GetUserChurnRisk"
    target: "flow://GetUserChurnRisk"
    inputs:
      "userid": string
        description: "user id, not required"
        label: "userid"
        is_required: False
        is_user_input: False
    outputs:
      "ChurnRisk": number
        description: "user churn risk"
        label: "ChurnRisk"
        is_displayable: False
        filter_from_agent: False
        complex_data_type_name: "lightning__numberType"
